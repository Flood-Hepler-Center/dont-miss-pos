rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isStaffOrAdmin() {
      return isAuthenticated();
    }
    
    // Menu categories: Public read, admin write
    match /menuCategories/{categoryId} {
      allow read: if true;
      allow write: if true; // Temporarily allow for development
    }

    // Menu items: Public read, admin write
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if true; // Temporarily allow for development
    }

    // Recipes
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if true; // TODO: Change to isAuthenticated() in production
    }
    
    // Orders: Public create, staff manage
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true; // Customers can create orders
      allow update, delete: if true; // TODO: Change to isAuthenticated() in production
    }
    
    // Tables: Public read, staff write
    match /tables/{tableId} {
      allow read: if true;
      allow write: if true; // TODO: Change to isAuthenticated() in production
    }
    
    // Payments: Staff only
    match /payments/{paymentId} {
      allow read, write: if true; // TODO: Change to isAuthenticated() in production
    }
    
    // Receipt sequences: Allow all for cashier operations
    match /receiptSequences/{sequenceId} {
      allow read, write: if true; // TODO: Change to isAuthenticated() in production
    }
    
    // Order sequences: Allow all for customer and staff operations
    match /orderSequences/{sequenceId} {
      allow read, write: if true; // TODO: Change to isAuthenticated() in production
    }
    
    // Inventory: Admin only (or anyone for order deduction)
    match /inventory/{itemId} {
      allow read: if true;
      allow write: if true; // Required for client-side inventory deduction
    }
    
    // Stock movements: Admin only
    match /stockMovements/{movementId} {
      allow read: if true;
      allow create: if true; // Required for client-side inventory deduction logs
      allow update, delete: if false;
    }
    
    // Settings: Public read (for merchant info), admin write
    match /settings/{docId} {
      allow read: if true;
      allow write: if true; // TODO: Change to isAuthenticated() in production
    }
    
    // Sessions (customer/staff): Allow create, authenticated update
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }
    
    // Audit logs: Admin read only
    match /auditLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false; // System only
    }
    
    // Staff calls: Customers can create, staff can read/update
    match /staffCalls/{callId} {
      allow read: if true;
      allow create: if true; // Customers can call staff
      allow update: if true; // Staff can acknowledge/complete
      allow delete: if false;
    }
    
    // Bookings: Staff and admin manage
    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if true; // Staff/admin can create, update, delete bookings
    }

    // Expense Management Collections
    match /expense_documents/{docId} {
      allow read, write: if true; // Admin manage expense documents
    }

    match /expense_lines/{lineId} {
      allow read, write: if true; // Admin manage expense line items
    }

    match /expense_skus/{skuId} {
      allow read, write: if true; // Admin manage SKU catalog
    }

    match /expense_vendors/{vendorId} {
      allow read, write: if true; // Admin manage vendors
    }

    match /expense_ai_jobs/{jobId} {
      allow read, write: if true; // Admin manage AI pipeline jobs
    }
  }
}
