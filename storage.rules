rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Menu item images: Public read, admin write
    match /menu-items/{itemId}/{fileName} {
      allow read: if true; // Public read for customer menu
      allow write: if request.auth != null && // Admin only
                      request.resource.size < 2 * 1024 * 1024 && // Max 2MB
                      request.resource.contentType.matches('image/.*'); // Images only
    }

    // Receipt logo: Public read, admin write
    match /receipts/logo.png {
      allow read: if true;
      allow write: if request.auth != null &&
                      request.resource.size < 500 * 1024; // Max 500KB
    }

    // Expense receipts: Public read for AI processing, validated write
    match /expense_receipts/{fileName} {
      allow read: if true; // Public read needed for server + OpenRouter AI
      allow write: if request.resource.size < 10 * 1024 * 1024 && // Max 10MB
                      request.resource.contentType.matches('image/.*'); // Images only
    }

    // Manual expense receipts and other expense docs: Public read, validated write
    match /expenses/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024 && // Max 10MB
                      request.resource.contentType.matches('image/.*'); // Images only
    }

    // Temporary uploads: Authenticated write, short-lived
    match /temp/{fileName} {
      allow read, write: if request.auth != null &&
                            request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }
  }
}
